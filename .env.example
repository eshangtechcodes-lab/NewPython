# ====================================
# EShangApi 环境配置模板
# 复制本文件为 .env 并填入实际值
# ====================================

# 应用设置
DEBUG=True

# 达梦数据库
DM_HOST=192.168.1.99
DM_PORT=5236
DM_USER=NEWPYTHON
DM_PASSWORD=你的密码
DM_DATABASE=DMNEW

# Oracle（仅验证测试用）
ORA_USER=highway_exchange
ORA_PASSWORD=你的密码
ORA_DSN=127.0.0.1/orcl

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_REVENUE_TREND_DB=1

# AES 加解密
AES_KEY=eshangapi2025key
AES_IV=eshangapi2025iv!

# 日志
LOG_DIR=logs
LOG_LEVEL=INFO
